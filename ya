local function updateStareLine(originPos,targetPos)
    if not stareLine or not stareLinePart then return end
    pcall(function()
        local dir=targetPos-originPos; local dist=dir.Magnitude
        if dist<0.1 then return end
        stareLinePart.CFrame=CFrame.lookAt(originPos,targetPos)
        stareLine.Length=dist; stareLine.CFrame=CFrame.new(0,0,-dist/2)
    end)
end


local function findPlayer(input)
    if not input or input=="" then return nil end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.DisplayName:lower():sub(1,#input)==input:lower() then return p end
    end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.Name:lower():sub(1,#input)==input:lower() then return p end
    end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player then
            if p.DisplayName:lower():find(input:lower(),1,true) or
               p.Name:lower():find(input:lower(),1,true) then return p end
        end
    end
    return nil
end

local function findPlayers(input)
    if not input or input=="" then return {} end
    local results={}; local seen={}
    for _,name in ipairs(splitStr(input,",")) do
        name=name:match("^%s*(.-)%s*$")
        if name~="" then
            local found=findPlayer(name)
            if found and not seen[found] then seen[found]=true; table.insert(results,found) end
        end
    end
    return results
end


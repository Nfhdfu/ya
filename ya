UIS.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.UserInputType~=Enum.UserInputType.Keyboard then return end
    local keyName=input.KeyCode.Name
    if keyName=="K" then setGuiVisible(not guiVisible) return end
    if #keyName~=1 then return end
    local focused=UIS:GetFocusedTextBox(); if focused then return end
    for _,pair in ipairs(keyPairList) do
        local kb,fn=pair[1],pair[2]
        if kb and kb.Text~="" and kb.Text:upper()==keyName:upper() then fn() end
    end
end)

local killAllTick=0
task.spawn(function()
    while true do task.wait(0.001)
        if killAllEnabled then
            killAllTick=killAllTick+1
            local myChar=player.Character; if not myChar then continue end
            local myRoot=myChar:FindFirstChild("HumanoidRootPart"); if not myRoot then continue end
            while #killAllActive<3 and #killAllQueue>0 do
                local nxt=table.remove(killAllQueue,1)
                if nxt and isAlive(nxt) then table.insert(killAllActive,nxt) end
            end
            if #killAllActive==0 and #killAllQueue==0 then
                local fresh=buildKillAllQueue(); if #fresh>0 then killAllQueue=fresh end
            end
            local yOffset=(killAllTick%2==0) and 1 or 0
            local newActive={}
            for _,t in ipairs(killAllActive) do
                if isAlive(t) then
                    local tc=t.Character; local tr=tc and tc:FindFirstChild("HumanoidRootPart")
                    if tr then pcall(function() tr.CFrame=myRoot.CFrame*CFrame.new(1.5,yOffset,-2.5) end) end
                    table.insert(newActive,t)
                end
            end
            killAllActive=newActive
        end
    end
end)


local function hookCharacterKill(targetPlayer,char)
    local hum=char:WaitForChild("Humanoid",5); if not hum then return end
    hum.Died:Connect(function()
        if not killNotifEnabled then return end
        if targetPlayer~=player and not watchList[targetPlayer.Name] then return end
        local creatorTag=hum:FindFirstChild("creator"); local killerPlayer=nil
        if creatorTag then
            if creatorTag:IsA("ObjectValue") and creatorTag.Value then
                if creatorTag.Value:IsA("Player") then killerPlayer=creatorTag.Value
                elseif creatorTag.Value:IsA("Model") then killerPlayer=Players:GetPlayerFromCharacter(creatorTag.Value) end
            elseif creatorTag:IsA("StringValue") and creatorTag.Value~="" then
                killerPlayer=Players:FindFirstChild(creatorTag.Value)
            end
        end
        local ks=killerPlayer and (killerPlayer.DisplayName.." (@"..killerPlayer.Name..")") or "Unknown"
        if targetPlayer==player then showNotif("You were killed by "..ks)
        else showNotif(targetPlayer.DisplayName.." (@"..targetPlayer.Name..") was killed by "..ks) end
    end)
end

local function connectSelfKill()
    local function hookSelf(c) hookCharacterKill(player,c) end
    if player.Character then hookSelf(player.Character) end
    player.CharacterAdded:Connect(function(c) task.wait(0.5) hookSelf(c) end)
end

local function getPlayerHP(p)
    local char=p.Character; if not char then return nil,nil end
    local hum=char:FindFirstChildOfClass("Humanoid"); if not hum then return nil,nil end
    return math.floor(hum.Health), math.floor(hum.MaxHealth)
end

local function getHPColor(hp,maxhp)
    if not hp or not maxhp or maxhp==0 then return Color3.fromRGB(200,200,200) end
    local pct=hp/maxhp
    if pct>0.6 then return Color3.fromRGB(80,255,80)
    elseif pct>0.3 then return Color3.fromRGB(255,200,50)
    else return Color3.fromRGB(255,60,60) end
end

local function createHitboxBoxes(char,color,storage)
    for _,part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") and BODY_SET[part.Name] then
            local sel=Instance.new("SelectionBox")
            sel.Adornee=part; sel.Color3=color; sel.LineThickness=0.02
            sel.SurfaceTransparency=1; sel.Parent=Workspace; table.insert(storage,sel)
        end
    end
end


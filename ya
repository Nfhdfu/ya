local tpunaEnabled = false; local tpunaConn = nil
local function toggleTPUna()
    tpunaEnabled = not tpunaEnabled
    TPUnaButton.Text = tpunaEnabled and "TP Unanchored: ON" or "TP Unanchored: OFF"
    TPUnaButton.BackgroundColor3 = tpunaEnabled and Color3.fromRGB(0,150,0) or Color3.fromRGB(50,50,50)
    if tpunaEnabled then
        task.spawn(function()
            local fti = firetouchinterest or (getgenv and getgenv().firetouchinterest)
            while tpunaEnabled do
                local ch = player.Character
                local myRoot = ch and ch:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    local inp = TPUnaTargetBox.Text:match("^%s*(.-)%s*$")
                    if inp == "" and not grabtoolsEnabled then
                        local tools = {}
                        for _, obj in ipairs(workspace:GetChildren()) do
                            if obj:IsA("Tool") then
                                local handle = obj:FindFirstChild("Handle")
                                if handle then table.insert(tools, handle) end
                            end
                        end
                        local count = #tools
                        for i, handle in ipairs(tools) do
                            pcall(function()
                                local angle = (2 * math.pi / math.max(count, 1)) * (i - 1)
                                local offset = Vector3.new(math.cos(angle) * 10, 0, math.sin(angle) * 10)
                                handle.CFrame = CFrame.new(myRoot.Position + offset)
                                if fti then
                                    fti(handle, myRoot, 0)
                                    fti(handle, myRoot, 1)
                                end
                            end)
                        end
                    else
                        local t = findPlayer(inp)
                        if t and t.Character then
                            local tr = t.Character:FindFirstChild("HumanoidRootPart")
                            if tr then
                                for _, obj in ipairs(workspace:GetChildren()) do
                                    if obj:IsA("Tool") then
                                        pcall(function()
                                            local handle = obj:FindFirstChild("Handle")
                                            if not handle then return end
                                            handle.CFrame = tr.CFrame
                                            if fti then
                                                fti(handle, tr, 0)
                                                fti(handle, tr, 1)
                                            end
                                        end)
                                    end
                                end
                            end
                        end
                    end
                end
                task.wait(0.001)
            end
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj:IsA("Tool") then
                    pcall(function()
                        local handle = obj:FindFirstChild("Handle")
                        if handle then
                            local bp = handle:FindFirstChildOfClass("BodyPosition")
                            if bp then bp:Destroy() end
                            local bg = handle:FindFirstChildOfClass("BodyGyro")
                            if bg then bg:Destroy() end
                        end
                    end)
                end
            end
        end)
    else

    end
end

local deadSpawnEnabled = false
local lastDeadCFrame = nil
local deadSpawnDiedConn = nil
local deadSpawnSpawnConn = nil

local function toggleDeadSpawn()
    deadSpawnEnabled = not deadSpawnEnabled
    DeadSpawnButton.Text = deadSpawnEnabled and "Dead Spawn: ON" or "Dead Spawn: OFF"
    DeadSpawnButton.BackgroundColor3 = deadSpawnEnabled and Color3.fromRGB(0,150,0) or Color3.fromRGB(50,50,50)
    if deadSpawnEnabled then
        local function hookDied(char)
            if deadSpawnDiedConn then deadSpawnDiedConn:Disconnect() deadSpawnDiedConn = nil end
            local hum = char:WaitForChild("Humanoid", 5)
            if not hum then return end
            deadSpawnDiedConn = hum.Died:Connect(function()
                if not deadSpawnEnabled then return end
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then lastDeadCFrame = root.CFrame end
            end)
        end
        if player.Character then hookDied(player.Character) end
        if deadSpawnSpawnConn then deadSpawnSpawnConn:Disconnect() deadSpawnSpawnConn = nil end
        deadSpawnSpawnConn = player.CharacterAdded:Connect(function(newChar)
            hookDied(newChar)
            if lastDeadCFrame then
                local savedCF = lastDeadCFrame
                wait(1)
                if not deadSpawnEnabled then return end
                local root = newChar:FindFirstChild("HumanoidRootPart")
                if root then pcall(function() root.CFrame = savedCF end) end
            end
        end)
    else
        if deadSpawnDiedConn then deadSpawnDiedConn:Disconnect() deadSpawnDiedConn = nil end
        if deadSpawnSpawnConn then deadSpawnSpawnConn:Disconnect() deadSpawnSpawnConn = nil end
        lastDeadCFrame = nil
    end
end


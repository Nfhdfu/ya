local touchFlingEnabled=false; local touchFlingConn=nil
local FLING_FORCE=380

local function setupTouchFling()
    if touchFlingConn then touchFlingConn:Disconnect() touchFlingConn=nil end
    local char=player.Character; if not char then return end
    local root=char:FindFirstChild("HumanoidRootPart"); if not root then return end
    touchFlingConn=root.Touched:Connect(function(hit)
        if not touchFlingEnabled then return end
        local hitChar=hit.Parent; if not hitChar then return end
        local hitPlayer=Players:GetPlayerFromCharacter(hitChar)
        if not hitPlayer or hitPlayer==player then return end
        local hitRoot=hitChar:FindFirstChild("HumanoidRootPart"); if not hitRoot then return end
        local hitHum=hitChar:FindFirstChildOfClass("Humanoid")
        if not hitHum or hitHum.Health<=0 then return end
        local dir=(hitRoot.Position-root.Position)
        if dir.Magnitude<0.01 then dir=Vector3.new(1,0,0) end
        local flingDir=(dir.Unit+Vector3.new(0,0.5,0)).Unit
        pcall(function()
            local oldBV=hitRoot:FindFirstChild("WFlingBV"); if oldBV then oldBV:Destroy() end
            local oldBG=hitRoot:FindFirstChild("WFlingBG"); if oldBG then oldBG:Destroy() end
            local bg=Instance.new("BodyGyro")
            bg.Name="WFlingBG"; bg.MaxTorque=Vector3.new(1e6,1e6,1e6)
            bg.P=1e6; bg.CFrame=hitRoot.CFrame; bg.Parent=hitRoot
            local bv=Instance.new("BodyVelocity")
            bv.Name="WFlingBV"; bv.Velocity=flingDir*FLING_FORCE
            bv.MaxForce=Vector3.new(1e6,1e6,1e6); bv.P=1e6; bv.Parent=hitRoot
            task.delay(0.2,function()
                if bv and bv.Parent then bv:Destroy() end
                if bg and bg.Parent then bg:Destroy() end
            end)
        end)
    end)
end


            local rt=ch:FindFirstChild("HumanoidRootPart"); if not rt then return end
            local hum=ch:FindFirstChildOfClass("Humanoid"); if not hum then return end
            local speed=tonumber(TPWalkSpeedBox.Text) or 16
            local cf=camera.CFrame
            local move=Vector3.new(0,0,0)
            if UIS:IsKeyDown(Enum.KeyCode.W) then move=move+Vector3.new(cf.LookVector.X,0,cf.LookVector.Z).Unit end
            if UIS:IsKeyDown(Enum.KeyCode.S) then move=move-Vector3.new(cf.LookVector.X,0,cf.LookVector.Z).Unit end
            if UIS:IsKeyDown(Enum.KeyCode.A) then move=move-Vector3.new(cf.RightVector.X,0,cf.RightVector.Z).Unit end
            if UIS:IsKeyDown(Enum.KeyCode.D) then move=move+Vector3.new(cf.RightVector.X,0,cf.RightVector.Z).Unit end
            if move.Magnitude<0.1 then return end
            local newPos=rt.Position+move.Unit*speed*0.1
            pcall(function()
                rt.CFrame=CFrame.new(newPos)*CFrame.Angles(0,math.atan2(move.X,move.Z)+math.pi,0)
            end)
        end)
    else
        if tpwalkConn then tpwalkConn:Disconnect() tpwalkConn=nil end
    end
end


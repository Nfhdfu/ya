local function openMultiPanel(title, targetBox)
    plTitle.Text = title
    plOnAdd = function(name)
        local cur = targetBox.Text
        local found = false
        for v in (cur .. ","):gmatch("([^,]*),") do
            if v:match("^%s*(.-)%s*$") == name then found = true; break end
        end
        if not found then
            targetBox.Text = cur == "" and name or cur .. "," .. name
        end
    end
    plOnRemove = function(name)
        local parts = {}
        for v in (targetBox.Text .. ","):gmatch("([^,]*),") do
            local vt = v:match("^%s*(.-)%s*$")
            if vt ~= name and vt ~= "" then table.insert(parts, vt) end
        end
        targetBox.Text = table.concat(parts, ",")
    end
    plGetList = function()
        local t = {}
        for _, p in ipairs(findPlayers(targetBox.Text)) do t[p.Name] = true end
        return t
    end
    plRefresh(); plPanel.Visible = true
end

local function openSinglePanel(title, targetBox)
    plTitle.Text = title
    plOnAdd = function(name) targetBox.Text = name end
    plOnRemove = function(name)
        if targetBox.Text:match("^%s*(.-)%s*$") == name then targetBox.Text = "" end
    end
    plGetList = function()
        local t = {}
        local found = findPlayer(targetBox.Text:match("^%s*(.-)%s*$"))
        if found then t[found.Name] = true end
        return t
    end
    plRefresh(); plPanel.Visible = true
end

local function openListPanel(title, listTable, onAddExtra, onRemoveExtra)
    plTitle.Text = title
    plOnAdd = function(name)
        listTable[name] = true
        if onAddExtra then onAddExtra() end
        plRefresh()
    end
    plOnRemove = function(name)
        listTable[name] = nil
        if onRemoveExtra then onRemoveExtra() end
        plRefresh()
    end
    plGetList = function() return listTable end
    plRefresh(); plPanel.Visible = true
end


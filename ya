task.spawn(function()
    while true do task.wait(0.05)
        if stareEnabled then
            local myChar=player.Character; if not myChar then continue end
            local myRoot=myChar:FindFirstChild("HumanoidRootPart"); if not myRoot then continue end
            local myHead=myChar:FindFirstChild("Head")
            local originPos=myHead and myHead.Position or myRoot.Position
            local function getRH(char)
                local rh=char:FindFirstChild("RightHand") or char:FindFirstChild("RightLowerArm")
                if rh then return rh.Position end
                local ra=char:FindFirstChild("Right Arm"); if ra then return ra.Position end
                local rt=char:FindFirstChild("HumanoidRootPart"); if rt then return rt.Position end
            end
            local targetPos=nil
            local function isAliveChar(char)
                if not char then return false end
                local hum=char:FindFirstChildOfClass("Humanoid")
                return hum and hum.Health > 0
            end
            local nt=findPlayer(StareTargetBox.Text)
            if nt and isAliveChar(nt.Character) then
                targetPos=getRH(nt.Character)
                if targetPos then
                    pcall(function()
                        myRoot.CFrame=CFrame.new(myRoot.Position,Vector3.new(targetPos.X,myRoot.Position.Y,targetPos.Z))
                    end)
                end
            else
                local cr,cd=nil,25
                for _,p in ipairs(Players:GetPlayers()) do
                    if p~=player and isAliveChar(p.Character) then
                        local tr=p.Character:FindFirstChild("HumanoidRootPart")
                        if tr then
                            local d=(myRoot.Position-tr.Position).Magnitude
                            if d<=cd then cd=d; cr=p.Character end
                        end
                    end
                end
                if cr then
                    targetPos=getRH(cr)
                    if targetPos then
                        pcall(function()
                            myRoot.CFrame=CFrame.new(myRoot.Position,Vector3.new(targetPos.X,myRoot.Position.Y,targetPos.Z))
                        end)
                    end
                end
            end
            if targetPos then updateStareLine(originPos,targetPos)
            else local fwd=myRoot.CFrame*CFrame.new(0,0,-30); updateStareLine(originPos,fwd.Position) end
        end
    end
end)

task.spawn(function()
    while true do task.wait(0.5)
        if espEnabled then
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=player and p.Character then
                    local root=p.Character:FindFirstChild("HumanoidRootPart")
                    if root and not root:FindFirstChildOfClass("BillboardGui") then addESPFor(p)
                    else
                        local data=espData[p]
                        if data and data.hpLbl then
                            local hp,maxhp=getPlayerHP(p)
                            if hp then data.hpLbl.Text="HP "..hp.." / "..maxhp; data.hpLbl.TextColor3=getHPColor(hp,maxhp) end
                        end
                    end
                end
            end
        end
        if locateEnabled then
            local targets=findPlayers(LocateTextBox.Text)
            for p in pairs(locateData) do
                local still=false
                for _,t in ipairs(targets) do if t==p then still=true; break end end
                if not still then removeLocateFor(p) end
            end
            for _,t in ipairs(targets) do
                if t.Character then
                    local root=t.Character:FindFirstChild("HumanoidRootPart")
                    if root and not root:FindFirstChildOfClass("BillboardGui") then addLocateFor(t)
                    else
                        local data=locateData[t]
                        if data and data.hpLbl then
                            local hp,maxhp=getPlayerHP(t)
                            if hp then data.hpLbl.Text="HP "..hp.." / "..maxhp; data.hpLbl.TextColor3=getHPColor(hp,maxhp) end
                        end
                    end
                end
            end
        end
        if plPanel.Visible then plRefresh() end
    end
end)

local dragging,dragInput,dragStart,startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        dragging=true; dragStart=input.Position; startPos=MainFrame.Position
        input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dragging=false end end)
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then dragInput=input end
end)
UIS.InputChanged:Connect(function(input)
    if input==dragInput and dragging then
        local delta=input.Position-dragStart
        MainFrame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
    end
end)



